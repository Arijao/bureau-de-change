{
  "name": "bureau-de-change",
  "version": "0.3.4",
  "private": true,
  "description": "Application de gestion de bureau de change",
  "author": {
    "name": "Arijao Rado",
    "email": "arijao@gmail.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/copy-standalone-assets.js",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma generate && prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma generate && prisma db push --force-reset && npm run db:seed",
    "setup": "npm install && npm run db:push && npm run db:seed",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:seed:prod": "tsx prisma/seed.prod.ts",
    "prod:init": "npm run build && DATABASE_URL='file:./prisma/prod.db' prisma db push && DATABASE_URL='file:./prisma/prod.db' npm run db:seed:prod",
    "prod:start": "DATABASE_URL='file:./prisma/prod.db' npm run start",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "flag-icons": "^7.5.0",
    "jspdf": "^4.2.1",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "allowScripts": {
    "electron@41.7.2": true
  }
}
