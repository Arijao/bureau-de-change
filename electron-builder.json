{
  "appId": "com.bureau-de-change.app",
  "productName": "Travel EXChange",
  "asar": false,
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": "standalone"
    },
    {
      "from": "prisma",
      "to": "prisma"
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "linux": {
    "target": ["deb", "AppImage"],
    "category": "Office"
  },
  "win": {
    "target": "nsis"
  },
  "mac": {
    "target": "dmg",
    "category": "public.app-category.finance"
  }
}